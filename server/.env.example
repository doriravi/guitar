# ---------------------------------------------------------------------------
# Backend environment variables. Copy to .env (gitignored) and fill in.
# All have safe dev defaults in application.properties; set these to override.
# ---------------------------------------------------------------------------

# --- Core -----------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=dev
# PORT=8080
# JWT_SECRET=change-me-in-production
# COOKIE_SECURE=false              # true in production (HTTPS)
# FRONTEND_URL=http://localhost:5173
# DB_PATH=./data/guitarreach.db

# --- Email (verification + password reset) --------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Social sign-in (optional) -------------------------------------------
# Leave blank to keep social login disabled — the OAuth endpoints return 503
# and the frontend disables the corresponding button. Fill in to activate.
#
# Google OAuth 2.0 Web Client ID (https://console.cloud.google.com).
#   MUST match VITE_GOOGLE_CLIENT_ID on the frontend.
GOOGLE_CLIENT_ID=

# Facebook App ID + Secret (https://developers.facebook.com).
#   FACEBOOK_APP_ID MUST match VITE_FACEBOOK_APP_ID on the frontend.
#   FACEBOOK_APP_SECRET is server-only — never expose it to the browser.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Stripe (billing, optional in dev) ------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_MONTHLY=price_...

# --- Gemini (hand-photo analysis, optional) -------------------------------
# GEMINI_API_KEY=
