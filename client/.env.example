# ---------------------------------------------------------------------------
# Frontend environment variables (Vite). Copy to .env.local and fill in.
# Only VITE_-prefixed vars are exposed to the browser bundle.
# ---------------------------------------------------------------------------

# Backend API base URL.
VITE_API_URL=http://localhost:8080

# --- Social sign-in (optional) -------------------------------------------
# Leave blank to keep Google/Facebook buttons disabled (they show
# "not available yet"). Fill in to activate the real OAuth buttons.
#
# Google: OAuth 2.0 Web Client ID from https://console.cloud.google.com
#   APIs & Services > Credentials > Create Credentials > OAuth client ID.
#   Add http://localhost:5173 (and your prod domain) as Authorized
#   JavaScript origins. This MUST match GOOGLE_CLIENT_ID on the backend.
VITE_GOOGLE_CLIENT_ID=

# Facebook: App ID from https://developers.facebook.com (Facebook Login
#   product enabled). Add your domains under Valid OAuth Redirect URIs /
#   App Domains. This MUST match FACEBOOK_APP_ID on the backend.
VITE_FACEBOOK_APP_ID=
